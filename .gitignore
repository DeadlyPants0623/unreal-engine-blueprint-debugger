# Unreal Engine project ignores
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Plugin generated folders
Plugins/*/Binaries/
Plugins/*/Intermediate/

# IDE / tool metadata
.vs/
.idea/
*.VC.db
*.VC.opendb
*.suo
*.opensdf
*.sdf

# Generated project files
*.sln
*.xcodeproj
*.xcworkspace

# User-specific settings
*.DotSettings.user

# Unreal local-only content
Content/Developers/*

# Logs and transient files
*.log
*.tmp
*.cache

# Python / misc tooling caches
__pycache__/
*.pyc

# OS files
Thumbs.db
.DS_Store

# Node / tooling artifacts
node_modules/
package.json
package-lock.json

# Claude Code local settings
.claude/settings.local.json
